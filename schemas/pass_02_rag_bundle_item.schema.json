{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "chapter_id": {
      "type": "string"
    },
    "chapter_order": {
      "type": "integer"
    },
    "source_file": {
      "type": "string"
    },
    "chapter_type": {
      "type": "string",
      "enum": [
        "prologue",
        "chapter"
      ]
    },
    "chapter_number": {
      "type": [
        "integer",
        "null"
      ]
    },
    "chapter_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "chapter_kind": {
      "type": "string",
      "enum": [
        "narrative",
        "background",
        "analysis",
        "reflection",
        "conclusion",
        "appendix",
        "mixed",
        "other"
      ],
      "description": "Final dominant chapter mode. Confirm or correct the preliminary label based only on chapter evidence."
    },
    "summary_short": {
      "type": "string"
    },
    "summary_detailed": {
      "type": "string"
    },
    "summary_confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "key_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/key_event"
      },
      "description": "Chronological event list for this chapter. Use [] if no discrete event can be supported by evidence."
    },
    "entities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      },
      "description": "Entity list extracted from chapter evidence. Every entity must include a stable entity_id used by events and relationships."
    },
    "time_markers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/time_marker"
      },
      "description": "Normalized temporal signals with precision and uncertainty bounds."
    },
    "important_quotes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/quote_item"
      }
    },
    "open_loops": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chapter_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ambiguities_or_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chunks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chunk"
      },
      "description": "Ordered retrieval chunks rewritten into plain US English while preserving source meaning."
    },
    "schema_version": {
      "type": "string",
      "description": "Pipeline schema version string provided in extraction_context. Copy exactly and do not alter."
    },
    "pipeline_version": {
      "type": "string",
      "description": "Pipeline runtime version string provided in extraction_context. Copy exactly and do not alter."
    },
    "extraction_model": {
      "type": "string",
      "description": "LLM model identifier provided in extraction_context. Copy exactly and do not alter."
    },
    "relationships": {
      "type": "array",
      "description": "Typed graph relationships grounded in this chapter. Use [] when no relationship is supported by evidence.",
      "items": {
        "$ref": "#/$defs/relationship"
      }
    }
  },
  "required": [
    "chapter_id",
    "chapter_order",
    "source_file",
    "chapter_type",
    "chapter_number",
    "chapter_title",
    "chapter_kind",
    "summary_short",
    "summary_detailed",
    "summary_confidence",
    "themes",
    "key_events",
    "entities",
    "time_markers",
    "important_quotes",
    "open_loops",
    "chapter_keywords",
    "ambiguities_or_gaps",
    "chunks",
    "schema_version",
    "pipeline_version",
    "extraction_model",
    "relationships"
  ],
  "$defs": {
    "key_event": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "type": "integer",
          "description": "1-based narrative order of the event inside the chapter."
        },
        "event_summary": {
          "type": "string",
          "description": "One factual sentence describing what happened. Do not invent details."
        },
        "importance": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "involved_entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "consequences": {
          "type": "string"
        },
        "event_id": {
          "type": "string",
          "description": "Stable event identifier unique within the chapter, e.g., \"betrayal-003-event-001\"."
        }
      },
      "required": [
        "event_id",
        "sequence",
        "event_summary",
        "importance",
        "involved_entities",
        "consequences"
      ]
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonical_name": {
          "type": "string",
          "description": "Most complete explicit name supported by chapter text."
        },
        "entity_type": {
          "type": "string",
          "enum": [
            "person",
            "organization",
            "place",
            "work",
            "event",
            "concept",
            "other"
          ]
        },
        "role_in_chapter": {
          "type": "string"
        },
        "salience": {
          "type": "string",
          "enum": [
            "minor",
            "secondary",
            "major"
          ]
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entity_id": {
          "type": "string",
          "description": "Stable entity identifier unique within the chapter, e.g., \"betrayal-003-entity-002\"."
        }
      },
      "required": [
        "entity_id",
        "canonical_name",
        "entity_type",
        "role_in_chapter",
        "salience",
        "aliases"
      ]
    },
    "time_marker": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "description": "Raw time expression from chapter text."
        },
        "normalized": {
          "type": [
            "string",
            "null"
          ],
          "description": "Normalized date/time string when possible (ISO-like); otherwise null."
        },
        "certainty": {
          "type": "string",
          "enum": [
            "explicit",
            "inferred"
          ]
        },
        "related_event": {
          "type": "string"
        },
        "date_precision": {
          "type": "string",
          "enum": [
            "exact",
            "day",
            "month",
            "year",
            "decade",
            "approximate",
            "relative",
            "unknown"
          ],
          "description": "Temporal precision of the marker. Use \"unknown\" if precision cannot be inferred."
        },
        "date_earliest": {
          "type": [
            "string",
            "null"
          ],
          "description": "Earliest plausible normalized bound for this time marker, or null if unavailable."
        },
        "date_latest": {
          "type": [
            "string",
            "null"
          ],
          "description": "Latest plausible normalized bound for this time marker, or null if unavailable."
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "description": "Confidence in normalization and precision assignment."
        }
      },
      "required": [
        "label",
        "normalized",
        "certainty",
        "related_event",
        "date_precision",
        "date_earliest",
        "date_latest",
        "confidence"
      ]
    },
    "quote_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "speaker_or_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "text": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        }
      },
      "required": [
        "speaker_or_source",
        "text",
        "why_it_matters"
      ]
    },
    "chunk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "chunk_id": {
          "type": "string"
        },
        "chunk_order": {
          "type": "integer"
        },
        "source_paragraph_start": {
          "type": "integer"
        },
        "source_paragraph_end": {
          "type": "integer"
        },
        "chunk_text_source": {
          "type": "string"
        },
        "chunk_text_us_plain": {
          "type": "string",
          "description": "Plain US English rewrite preserving source meaning and factual fidelity."
        },
        "chunk_kind": {
          "type": "string",
          "enum": [
            "narrative",
            "analysis",
            "quote",
            "context",
            "other"
          ]
        },
        "entities_mentioned": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "time_markers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rewrite_quality": {
          "type": "string",
          "enum": [
            "pass",
            "review"
          ]
        },
        "fidelity_notes": {
          "type": "string"
        },
        "token_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Estimated token count for chunk_text_us_plain."
        },
        "previous_chunk_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Immediate previous chunk_id in chapter order, or null for the first chunk."
        },
        "next_chunk_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Immediate next chunk_id in chapter order, or null for the last chunk."
        },
        "keywords": {
          "type": "array",
          "description": "Sparse-search keywords grounded in this chunk text. Use [] when no specific keywords are available.",
          "items": {
            "type": "string"
          }
        },
        "bm25_boost_text": {
          "type": "string",
          "description": "Keyword-optimized text for sparse retrieval, combining chapter/chunk context terms without inventing facts."
        }
      },
      "required": [
        "chunk_id",
        "chunk_order",
        "source_paragraph_start",
        "source_paragraph_end",
        "chunk_text_source",
        "chunk_text_us_plain",
        "chunk_kind",
        "entities_mentioned",
        "aliases",
        "time_markers",
        "rewrite_quality",
        "fidelity_notes",
        "token_count",
        "previous_chunk_id",
        "next_chunk_id",
        "keywords",
        "bm25_boost_text"
      ]
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "description": "Directed edge between two chapter entities supported by explicit or strongly inferred evidence.",
      "properties": {
        "relationship_id": {
          "type": "string",
          "description": "Stable relationship identifier unique within the chapter, e.g., \"betrayal-003-rel-001\"."
        },
        "source_entity_id": {
          "type": "string",
          "description": "entity_id of the source node."
        },
        "target_entity_id": {
          "type": "string",
          "description": "entity_id of the target node."
        },
        "relationship_type": {
          "type": "string",
          "enum": [
            "MARRIED_TO",
            "PARENT_OF",
            "MENTORED_BY",
            "RIVAL_OF",
            "MEMBER_OF",
            "LEADER_OF",
            "FOUNDED",
            "EMPLOYED_BY",
            "PRECEDED_BY",
            "FOLLOWED_BY",
            "DURING",
            "CONCURRENT_WITH",
            "CAUSED",
            "LED_TO",
            "INFLUENCED",
            "MOTIVATED_BY",
            "SYMBOLIZES",
            "EXEMPLIFIES",
            "CONTRASTS_WITH",
            "LOCATED_IN",
            "BORN_IN",
            "TRAVELED_TO",
            "ASSOCIATED_WITH"
          ],
          "description": "Typed edge label chosen from controlled taxonomy. Never use free-form relation labels."
        },
        "description": {
          "type": "string",
          "description": "Short evidence-grounded rationale describing the relationship in this chapter context."
        },
        "evidence_chunk_ids": {
          "type": "array",
          "description": "chunk_id values that support this edge. Must reference chunk IDs present in this chapter output.",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "description": "Confidence that this relationship is supported by chapter evidence."
        },
        "valid_from": {
          "type": [
            "string",
            "null"
          ],
          "description": "Normalized temporal start bound for the relationship, or null when unknown."
        },
        "valid_to": {
          "type": [
            "string",
            "null"
          ],
          "description": "Normalized temporal end bound for the relationship, or null when unknown or ongoing."
        }
      },
      "required": [
        "relationship_id",
        "source_entity_id",
        "target_entity_id",
        "relationship_type",
        "description",
        "evidence_chunk_ids",
        "confidence",
        "valid_from",
        "valid_to"
      ]
    }
  }
}
